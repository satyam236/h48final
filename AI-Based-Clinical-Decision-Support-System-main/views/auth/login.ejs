<%- include('../partials/header', { cssFile: 'auth' }) %>

<div class="auth-container">
    <div class="auth-card glass-effect">
        <div class="auth-header">
            <h1 class="gradient-text">🏥 MediCare</h1>
            <p>Welcome back! Please login to your account.</p>
        </div>
        
        <form class="auth-form" action="/login" method="POST">
            <div class="form-group">
                <label for="role">Login as</label>
                <div class="custom-select">
                    <select id="role" name="role" required>
                        <option value="Patient">Patient</option>
                        <option value="Doctor">Doctor</option>
                        <option value="Admin">Admin</option>
                    </select>
                </div>
            </div>

            <div class="form-group">
                <label for="email">Email address</label>
                <input type="email" id="email" name="email" placeholder="patient@example.com" required>
            </div>

            <div class="form-group">
                <label for="password">Password</label>
                <input type="password" id="password" name="password" placeholder="••••••••" required>
            </div>

            <button type="submit" class="btn btn-primary btn-block">
                <span>Sign In</span>
            </button>
        </form>

        <div class="auth-footer">
            <p>Don't have an account? <a href="/signup" class="text-link">Sign up</a></p>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
